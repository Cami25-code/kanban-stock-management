# Variables utilisées par docker-compose.yml. Copier en .env et renseigner
# les valeurs avant de lancer `docker-compose up -d --build`.

# Générer avec : docker-compose run --rm backend php artisan key:generate --show
APP_KEY=

# URL publique du back-end et du front-end (à adapter en production : IP du VPS
# ou nom de domaine). REACT_APP_API_URL est figée dans le build du front-end :
# toute modification nécessite de reconstruire l'image (`docker-compose build frontend`).
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:8000/api

# Base de données MySQL
DB_DATABASE=kanban_stock
DB_USERNAME=kanban_user
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme_root
